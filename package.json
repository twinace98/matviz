{
  "name": "vscode-matviz",
  "displayName": "MatViz - Crystal Structure Viewer",
  "description": "Interactive 3D crystal structure visualization for CIF, POSCAR, XSF, XYZ, PDB, Gaussian Cube, and more",
  "version": "0.15.2",
  "license": "MIT",
  "publisher": "matviz",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "matviz.crystalViewer",
        "displayName": "Crystal Structure Viewer",
        "selector": [
          {
            "filenamePattern": "*.cif"
          },
          {
            "filenamePattern": "*.xsf"
          },
          {
            "filenamePattern": "*.axsf"
          },
          {
            "filenamePattern": "*.poscar"
          },
          {
            "filenamePattern": "*.vasp"
          },
          {
            "filenamePattern": "POSCAR"
          },
          {
            "filenamePattern": "CONTCAR"
          },
          {
            "filenamePattern": "XDATCAR"
          },
          {
            "filenamePattern": "*.xyz"
          },
          {
            "filenamePattern": "*.pdb"
          },
          {
            "filenamePattern": "*.cube"
          },
          {
            "filenamePattern": "*.cub"
          },
          {
            "filenamePattern": "CHGCAR"
          },
          {
            "filenamePattern": "AECCAR0"
          },
          {
            "filenamePattern": "AECCAR2"
          },
          {
            "filenamePattern": "PARCHG"
          },
          {
            "filenamePattern": "geometry.in"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "matviz.crystalViewer",
        "displayName": "Crystal Structure Viewer",
        "selector": [
          {
            "filenamePattern": "*.in"
          },
          {
            "filenamePattern": "*.out"
          },
          {
            "filenamePattern": "*.stdin"
          },
          {
            "filenamePattern": "*.stdout"
          },
          {
            "filenamePattern": "*.pw"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "matviz.openInViewer",
          "when": "resourceExtname =~ /^\\.(in|out|stdin|stdout|pw)$/",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "matviz.openInViewer",
        "title": "Open in MatViz",
        "icon": "$(graph)"
      },
      {
        "command": "matviz.resetCamera",
        "title": "MatViz: Reset Camera"
      },
      {
        "command": "matviz.toggleBonds",
        "title": "MatViz: Toggle Bonds"
      },
      {
        "command": "matviz.viewAlongDirection",
        "title": "MatViz: View Along Direction [uvw]"
      },
      {
        "command": "matviz.viewNormalToPlane",
        "title": "MatViz: View Normal to Plane (hkl)"
      },
      {
        "command": "matviz.addLatticePlane",
        "title": "MatViz: Add Lattice Plane (hkl)"
      },
      {
        "command": "matviz.clearLatticePlanes",
        "title": "MatViz: Clear Lattice Planes"
      },
      {
        "command": "matviz.screenshot",
        "title": "MatViz: Export Screenshot"
      },
      {
        "command": "matviz.exportCif",
        "title": "MatViz: Export as CIF"
      },
      {
        "command": "matviz.exportPoscar",
        "title": "MatViz: Export as POSCAR"
      },
      {
        "command": "matviz.showWulff",
        "title": "MatViz: Show Wulff Construction"
      },
      {
        "command": "matviz.clearWulff",
        "title": "MatViz: Clear Wulff Construction"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test:visual": "node dist/test-visual-harness.js",
    "test:visual:update": "node dist/test-visual-harness.js --update-baseline",
    "package": "vsce package",
    "install-skill": "bash scripts/install-skill.sh",
    "install-all": "npm run build && npx @vscode/vsce package --no-dependencies && code --install-extension vscode-matviz-$npm_package_version.vsix --force && npm run install-skill"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.170.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "three": "^0.170.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "puppeteer": "^24.41.0"
  }
}
